# ------------------------------------------------------------
# ANALYSIS 3c: SIU frequencies in ambiguous conditions (Over vs Under)
# ------------------------------------------------------------
# Question:
#   In ambiguous conditions, is advice more likely to be ignored
#   (SIU = 0) in Over vs Under trials?
#
# Approach:
#   (i) Descriptive distribution across SIU categories (0 / between / 1)
#   (ii) Binomial tests within each advice direction (heuristic p = 0.5)
#   (iii) Direct Over vs Under comparison using 2×2 tests and a logistic model
#
# Note:
#   These frequency-based tests treat trials as independent; a mixed-effects
#   logistic model can be added as a robustness check if desired.
# ------------------------------------------------------------


# Define ambiguous subset and SIU categories
ambig <- d_siu %>%
  filter(
    (Directed_Motion == "Present" & Synchrony == "Low") |
      (Directed_Motion == "Absent"  & Synchrony == "High")
  ) %>%
  filter(is.finite(s))

# Classify SIU into 3 categories within ambiguous trials
ambig_scat <- ambig %>%
  mutate(
    SIU_cat = case_when(
      s == 0              ~ "SIU_0",        # ignored advice
      s > 0 & s < 1       ~ "SIU_between",  # partially used advice
      s == 1              ~ "SIU_1",        # fully aligned with advice
      TRUE                ~ NA_character_
    )
  ) %>%
  filter(!is.na(SIU_cat))


# ------------------------------------------------------------
# ANALYSIS 3c.i: Ambiguous OVER trials — category distribution + SIU=0 vs SIU>0
# ------------------------------------------------------------

ambig_over_trials <- ambig_scat %>%
  filter(Advice == "Over")

n_ambig_over_total <- nrow(ambig_over_trials)

ambig_over_counts <- table(ambig_over_trials$SIU_cat)
ambig_over_props  <- prop.table(ambig_over_counts)

cat("\n[2.2] Ambiguous OVER trials: counts by SIU category:\n")
print(ambig_over_counts)
cat("\n[2.2] Ambiguous OVER trials: proportions by SIU category:\n")
print(ambig_over_props)

# Collapse to SIU = 0 vs SIU > 0 (SIU_between + SIU_1)
ambig_over_sub <- ambig_over_trials %>%
  filter(SIU_cat %in% c("SIU_0", "SIU_between", "SIU_1"))

n_ambig_over_s0     <- sum(ambig_over_sub$SIU_cat == "SIU_0")
n_ambig_over_s_non0 <- sum(ambig_over_sub$SIU_cat != "SIU_0")
n_ambig_over_sub    <- n_ambig_over_s0 + n_ambig_over_s_non0

cat("\n[2.2] Ambiguous OVER: SIU = 0 vs SIU > 0 (within Over trials):\n")
cat("  n(SIU = 0)      =", n_ambig_over_s0,     "\n")
cat("  n(SIU > 0)      =", n_ambig_over_s_non0, "\n")
cat("  Prop SIU = 0    =", n_ambig_over_s0     / n_ambig_over_sub, "\n")
cat("  Prop SIU > 0    =", n_ambig_over_s_non0 / n_ambig_over_sub, "\n")

cat("\n[2.2] Binomial test (Ambiguous OVER; SIU=0 vs SIU>0):\n")
print(binom.test(
  x = n_ambig_over_s0,
  n = n_ambig_over_sub,
  p = 0.5  # H0: equally likely to ignore vs use in ambiguous Over trials
))


# ------------------------------------------------------------
# ANALYSIS 3c.ii: Ambiguous UNDER trials — category distribution + SIU=0 vs SIU>0
# ------------------------------------------------------------

ambig_under_trials <- ambig_scat %>%
  filter(Advice == "Under")

n_ambig_under_total <- nrow(ambig_under_trials)

ambig_under_counts <- table(ambig_under_trials$SIU_cat)
ambig_under_props  <- prop.table(ambig_under_counts)

cat("\n[2.3] Ambiguous UNDER trials: counts by SIU category:\n")
print(ambig_under_counts)
cat("\n[2.3] Ambiguous UNDER trials: proportions by SIU category:\n")
print(ambig_under_props)

# Collapse to SIU = 0 vs SIU > 0
ambig_under_sub <- ambig_under_trials %>%
  filter(SIU_cat %in% c("SIU_0", "SIU_between", "SIU_1"))

n_ambig_under_s0     <- sum(ambig_under_sub$SIU_cat == "SIU_0")
n_ambig_under_s_non0 <- sum(ambig_under_sub$SIU_cat != "SIU_0")
n_ambig_under_sub    <- n_ambig_under_s0 + n_ambig_under_s_non0

cat("\n[2.3] Ambiguous UNDER: SIU = 0 vs SIU > 0 (within Under trials):\n")
cat("  n(SIU = 0)      =", n_ambig_under_s0,     "\n")
cat("  n(SIU > 0)      =", n_ambig_under_s_non0, "\n")
cat("  Prop SIU = 0    =", n_ambig_under_s0     / n_ambig_under_sub, "\n")
cat("  Prop SIU > 0    =", n_ambig_under_s_non0 / n_ambig_under_sub, "\n")

cat("\n[2.3] Binomial test (Ambiguous UNDER; SIU=0 vs SIU>0):\n")
print(binom.test(
  x = n_ambig_under_s0,
  n = n_ambig_under_sub,
  p = 0.5  # H0: equally likely to ignore vs use in ambiguous Under trials
))


# ------------------------------------------------------------
# ANALYSIS 3c.iii: Direct comparison (ambiguous only)
#   P(SIU = 0 | Over) vs P(SIU = 0 | Under)
# ------------------------------------------------------------

# Binary indicator within ambiguous trials:
#   SIU_zero = 1 if s == 0 (ignored advice), 0 if s > 0 (used to any extent)
ambig_bin <- ambig %>%
  mutate(
    SIU_zero = as.integer(s == 0)
  )

# 2×2 table: Advice (Over / Under) × SIU_zero (0 / 1)
tab_ambig_advice_siu <- table(
  Advice   = ambig_bin$Advice,
  SIU_zero = ambig_bin$SIU_zero
)

cat("\n[2.4] Ambiguous trials: 2x2 table Advice x SIU_zero:\n")
print(tab_ambig_advice_siu)

# Extract counts (for readability)
ambig_over_s0     <- tab_ambig_advice_siu["Over",  "1"]
ambig_over_s_gt0  <- tab_ambig_advice_siu["Over",  "0"]
ambig_under_s0    <- tab_ambig_advice_siu["Under", "1"]
ambig_under_s_gt0 <- tab_ambig_advice_siu["Under", "0"]

cat("\n[2.4] Counts (Ambiguous):\n")
cat("  Over:  SIU = 0  =", ambig_over_s0,    ", SIU > 0 =", ambig_over_s_gt0,  "\n")
cat("  Under: SIU = 0  =", ambig_under_s0,   ", SIU > 0 =", ambig_under_s_gt0, "\n")

# Two-proportion test: P(SIU = 0 | Over) vs P(SIU = 0 | Under)
ambig_prop_test <- prop.test(
  x = c(ambig_over_s0,  ambig_under_s0),                        # SIU = 0 counts
  n = c(ambig_over_s0 + ambig_over_s_gt0,                       # total Over (ambig)
        ambig_under_s0 + ambig_under_s_gt0)                     # total Under (ambig)
)

cat("\n[2.4] Two-proportion test (Ambiguous): P(SIU=0 | Over) vs P(SIU=0 | Under):\n")
print(ambig_prop_test)

# Chi-square test on full 2×2 table (equivalent)
ambig_chi <- chisq.test(tab_ambig_advice_siu)
cat("\n[2.4] Chi-square test on 2x2 table (Ambiguous):\n")
print(ambig_chi)

# Logistic regression (Ambiguous only): SIU_zero ~ Advice
# Over as reference level, so coefficient = Under vs Over
ambig_bin$Advice <- relevel(ambig_bin$Advice, ref = "Over")

glm_ambig_siu <- glm(
  SIU_zero ~ Advice,
  family = binomial,
  data   = ambig_bin
)

cat("\n[2.4] Logistic regression (Ambiguous): SIU_zero ~ Advice (ref = Over):\n")
summary(glm_ambig_siu)

# Odds ratio and 95% CI for Under vs Over within ambiguous trials
beta_ambig   <- coef(glm_ambig_siu)["AdviceUnder"]
se_ambig     <- sqrt(vcov(glm_ambig_siu)["AdviceUnder", "AdviceUnder"])
OR_ambig     <- exp(beta_ambig)
CI_low_ambig <- exp(beta_ambig - 1.96 * se_ambig)
CI_high_ambig<- exp(beta_ambig + 1.96 * se_ambig)

cat("\n[2.4] Odds ratio (Under vs Over) for SIU = 0 (Ambiguous trials):\n")
cat("  OR =", OR_ambig,
    "  95% CI [", CI_low_ambig, ",", CI_high_ambig, "]\n")


