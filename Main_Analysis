# ------------------------------------------------------------------------------
# Quality Control Participant Level 1: Low Variance in Slider Responses (R1) 
# ------------------------------------------------------------------------------

# Flag participants whose R1 variability is unusually low

# For each participant, we compute the within-person SD of their 
# initial slider responses (R1) across all trials.

# Z-score definition (participant i):
# z_i = (SD_i  -  mean(SD across participants) ) / sd(SD across participants)

# z ≈ 0   → typical variability for the group
# z < 0   → lower-than-average variability (flatter response profile)
# z > 0   → higher-than-average variability

# We flag participants with z < -2 as "unusually flat". 

output_dir <- "Output"

# Read data set (already excluding technical outliers)
long_table <- read_csv(
  file.path(output_dir, "all_participants_excl_technical_outliers_long.csv"),
  show_col_types = FALSE
)

# Safety checks
if (!("participant" %in% names(long_table)))
  stop("Column 'participant' not found in long data.")
if (!("slider_response1_2.response" %in% names(long_table)))
  stop("Column 'slider_response1_2.response' not found in long data.")

# Make sure R1 is numeric (in case it was read as character)
long_table <- long_table %>%
  mutate(slider_response1_2.response = suppressWarnings(as.numeric(slider_response1_2.response)))

# Compute SD and N per participant on R1
qc_low_var <- long_table %>%
  group_by(participant) %>%
  summarise(
    n_trials_used = sum(!is.na(slider_response1_2.response)),
    sd_slider_r1  = sd(slider_response1_2.response, na.rm = TRUE),
    .groups = "drop"
  )

# Z-score across participants; flag z < -2
qc_low_var <- qc_low_var %>%
  mutate(
    z_sd = as.numeric(scale(sd_slider_r1)),
    flag_low_var = !is.na(z_sd) & z_sd < -2
  ) %>%
  arrange(z_sd)

