# Use conflict trials only
d_dist <- d0_conflict %>%
  filter(advice_opposite == 1) %>%
  mutate(
    absX = abs(X),            # distance of advice from midpoint
    switched = factor(switch_any, levels = c(0,1),
                      labels = c("No_Switch","Switch"))
  )

# ------------------------------------------------------------
# 1) Descriptive table
# ------------------------------------------------------------

dist_summary <- d_dist %>%
  group_by(cat_R1, switched) %>%
  summarise(
    n = n(),
    mean_absX = mean(absX, na.rm = TRUE),
    sd_absX = sd(absX, na.rm = TRUE),
    .groups = "drop"
  )

cat("\nDistance from midpoint (|X|) by R1 and Switching:\n")
print(dist_summary)

# ------------------------------------------------------------
# 2) Visual check (boxplot style summary)
# ------------------------------------------------------------

library(ggplot2)

ggplot(d_dist, aes(x = switched, y = absX, fill = cat_R1)) +
  geom_boxplot(outlier.shape = NA, alpha = .6) +
  geom_jitter(width = .15, alpha = .3) +
  facet_wrap(~cat_R1) +
  theme_minimal() +
  labs(
    title = "Distance of Advice from Midpoint (|X|)",
    subtitle = "Conflict trials only",
    x = "Switch",
    y = "|Advice from midpoint|",
    fill = "Initial category (R1)"
  )

# ------------------------------------------------------------
# 3) Mixed model: does |X| predict switching?
# ------------------------------------------------------------

library(lme4)
library(car)

d_dist <- d_dist %>%
  mutate(absX_z = as.numeric(scale(absX)))

m_dist <- glmer(
  switch_any ~ absX_z * cat_R1 + (1 | participant),
  data = d_dist,
  family = binomial
)

cat("\n\nModel: Does advice distance predict switching?\n")
summary(m_dist)

cat("\nType III tests:\n")
print(car::Anova(m_dist, type = "III"))


d_check <- d0_conflict %>%
  filter(advice_opposite == 1) %>%
  mutate(A = X - R1, absA = abs(A), absX = abs(X), absR1 = abs(R1))

summary(d_check$absA)
summary(d_check$absX)

# how many violate the ±25 rule?
d_check %>% summarise(
  n = n(),
  n_absA_gt_26 = sum(absA > 26, na.rm = TRUE),
  n_absX_gt_25 = sum(absX > 25, na.rm = TRUE)
)
