)

print(DM_within_S_diff_resp)
# 'estimate' here is Present - Absent in absolute confidence units (0..1)

# B) Synchrony within each level of Directed Motion
emm_S_within_DM_resp <- emmeans(m_conf, ~ Synchrony | Directed_Motion, type = "response")

# Ensure contrasts are computed on the response (0..1) scale
emm_S_within_DM_resp <- regrid(emm_S_within_DM_resp, transform = "response")

# All pairwise differences among Synchrony (High, Medium, Low); Tukey correction
S_within_DM_diff <- summary(
