eps     <- 1e-8   # numeric safety
gap_target <- 25  # focus on |X - R1| ≈ 25 units
gap_tol    <- 2 # half-unit tolerance; set to 0 if you want exact equality only

# Base: drop 'random', coerce, recode, finite 
