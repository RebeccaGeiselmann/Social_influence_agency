# ==============================================================================
# MAIN ANALYSES: SOCIAL INFORMATION USE (SIU)
# - Model 1: Advice × Directed Motion × Synchrony
# - Model 2: Confidence moderation (within–between decomposition)
# - EMMs (for supplement + Figure 4 style) and simple effects
#
# Notes:
# - SIU is modeled with beta GLMM (logit link) using glmmTMB
# - SIU is Smithson–Verkuilen “squeezed” into (0,1)
# - Contrasts are sum-to-zero (effect coding) for Type III Wald χ² tests
# - Confidence is decomposed into:
#     conf_WP_z = within-person centered and z-scaled
#     conf_BP_z = between-person mean confidence (participant mean), z-scaled
# - Advice magnitude is absA_z = z-scored |X − R1|
# ==============================================================================

# ==============================================================================
# 0) Helpers
# ==============================================================================

sv_squeeze <- function(x) {
  # Smithson–Verkuilen squeeze to map [0,1] -> (0,1)
  # uses sample size N of the vector provided
  N <- sum(is.finite(x))
  (x * (N - 1) + 0.5) / N
}

print_lrt <- function(m0, m1, label = "") {
  cat("\n---", label, "---\n")
  print(anova(m0, m1))
}

fmt_p <- function(p) ifelse(is.na(p), NA, ifelse(p < .001, "< .001", sprintf("%.3f", p)))

# ==============================================================================
# 1) Load + prep base data
# ==============================================================================

infile <- file.path(output_dir, "siu_trials_clean.csv")

d <- read_csv(infile, show_col_types = FALSE) %>%
  rename(
    R1 = slider_response1_2.response,   # initial estimate
    X  = agent_feedback,                # advice
    R2 = slider_response2_2.response,   # revised estimate
    s  = s                              # SIU
  ) %>%
  mutate(
    participant     = factor(participant),
    Directed_Motion = factor(str_to_title(directed_motion), levels = c("Present", "Absent")),
    Synchrony       = factor(str_to_title(synchrony),       levels = c("High", "Medium", "Low")),
    Advice          = factor(str_to_lower(feedback_type),   levels = c("under", "over"),
                             labels = c("Under", "Over")),
    
    # Advice distance
    A    = X - R1,
    absA = abs(A),
    
    # Confidence strength on 0–1
    conf_strength = pmin(pmax(abs(R1) / 100, 0), 1)
  ) %>%
  filter(is.finite(s)) %>%
  group_by(participant) %>%
  mutate(
    conf_mean_id = mean(conf_strength, na.rm = TRUE),
    conf_WP      = conf_strength - conf_mean_id,  # within-person deviation
    conf_BP      = conf_mean_id                   # between-person mean confidence
  ) %>%
  ungroup() %>%
  mutate(
    absA_z    = as.numeric(scale(absA)),
    conf_BP_z = as.numeric(scale(conf_BP)),
    conf_WP_z = as.numeric(scale(conf_WP))
  )

# Smithson–Verkuilen squeeze for DV into (0,1)
d <- d %>% mutate(s_sv = sv_squeeze(s))

# Sum-to-zero contrasts for Type III tests
contrasts(d$Advice)          <- contr.sum(2)
contrasts(d$Directed_Motion) <- contr.sum(2)
contrasts(d$Synchrony)       <- contr.sum(3)

# ==============================================================================
# 2) ANALYSIS 1: Structural model (Advice × Directed Motion × Synchrony)
# ==============================================================================

cat("\n====================\nANALYSIS 1: Structural SIU model\n====================\n")

# Baseline (no advice)
m_noAdvice <- glmmTMB(
  s_sv ~ absA_z + (1 | participant),
  family = beta_family(link = "logit"),
  data = d
)

# Advice only (no stimulus)
m_noStim <- update(m_noAdvice, . ~ . + Advice)

# Add stimulus main + interaction (DM * Synchrony)
m_addStim <- glmmTMB(
  s_sv ~ Advice + Directed_Motion * Synchrony + absA_z + (1 | participant),
  family = beta_family(link = "logit"),
  data = d
)

# Full structural model
m_full <- glmmTMB(
  s_sv ~ Advice * Directed_Motion * Synchrony + absA_z + (1 | participant),
  family = beta_family(link = "logit"),
  data = d
)

# Block tests (nested LRTs)
print_lrt(m_noAdvice, m_noStim,  "LRT: Add Advice (baseline -> Advice-only)")
print_lrt(m_noStim,   m_addStim, "LRT: Add Stimulus block (DM, Synch, DM×Synch)")
print_lrt(m_addStim,  m_full,    "LRT: Add Advice×Stimulus interaction block")

# Type III Wald χ² tests (full model)
cat("\n--- Type III Wald χ² tests (Structural full model) ---\n")
print(car::Anova(m_full, type = "III"))

# Optional: LRT for 3-way only
m_no3 <- update(m_full, . ~ . - Advice:Directed_Motion:Synchrony)
print_lrt(m_no3, m_full, "LRT: 3-way Advice×DM×Synchrony")

# ------------------------------------------------------------------------------
# EMMs + simple effects for Structural model (match your supplement tables)
# ------------------------------------------------------------------------------

# Hold covariate at mean (absA_z = 0)
at_struct <- list(absA_z = 0)

# Full cell means (Advice × DM × Synchrony)
emm_full_cells <- emmeans(
  m_full, ~ Advice * Directed_Motion * Synchrony,
  at = at_struct,
  type = "response"
)

# Simple effects (within each cell family)
# Advice within DM×Synchrony
se_advice_by_cell <- pairs(emm_full_cells, by = c("Directed_Motion", "Synchrony"), adjust = "holm")

# Synchrony within Advice×DM
se_syn_by_adv_dm <- pairs(emm_full_cells, by = c("Advice", "Directed_Motion"), adjust = "tukey")

# DM within Advice×Synchrony
se_dm_by_adv_syn <- pairs(emm_full_cells, by = c("Advice", "Synchrony"), adjust = "holm")

cat("\n--- EMMs: Advice×DM×Synchrony (Structural) ---\n")
print(emm_full_cells)

cat("\n--- Simple effects: Advice within each DM×Synchrony (Structural) ---\n")
print(se_advice_by_cell)

cat("\n--- Simple effects: Synchrony within each Advice×DM (Structural) ---\n")
print(se_syn_by_adv_dm)

cat("\n--- Simple effects: Directed Motion within each Advice×Synchrony (Structural) ---\n")
print(se_dm_by_adv_syn)

# Collapsed (averaged equally over the other factor) “mirror” contrasts + EMMs
# These correspond to the “mirror analysis” tables you asked for.

# Helper: differences on response scale (ΔSIU) rather than odds ratios
diff_resp_holm <- function(emm_obj, by_vars) {
  contrast(
    regrid(emm_obj, transform = "response"),
    method = "revpairwise",
    by = by_vars,
    adjust = "holm"
  )
}

# A) Advice effect within Directed Motion (collapsed over Synchrony)
emm_adv_by_dm <- emmeans(
  m_full, ~ Advice | Directed_Motion,
  at = at_struct,
  weights = "equal"
)
se_adv_by_dm <- diff_resp_holm(emm_adv_by_dm, by_vars = "Directed_Motion")

# B) Directed Motion effect within Advice (collapsed over Synchrony)
emm_dm_by_adv <- emmeans(
  m_full, ~ Directed_Motion | Advice,
  at = at_struct,
  weights = "equal"
)
se_dm_by_adv <- diff_resp_holm(emm_dm_by_adv, by_vars = "Advice")

# C) Advice effect within Synchrony (collapsed over Directed Motion)
emm_adv_by_syn <- emmeans(
  m_full, ~ Advice | Synchrony,
  at = at_struct,
  weights = "equal"
)
se_adv_by_syn <- diff_resp_holm(emm_adv_by_syn, by_vars = "Synchrony")

# D) Synchrony pairwise within Advice (collapsed over Directed Motion) — Tukey
emm_syn_by_adv <- emmeans(
  m_full, ~ Synchrony | Advice,
  at = at_struct,
  weights = "equal"
)
se_syn_by_adv <- pairs(regrid(emm_syn_by_adv, transform = "response"), adjust = "tukey")

