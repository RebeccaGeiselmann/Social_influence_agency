  m_full, ~ Advice * Directed_Motion,
  at = at_struct,
  weights = "equal",
  type = "response"
)

emm_adv_syn_collapsed <- emmeans(
  m_full, ~ Advice * Synchrony,
  at = at_struct,
  weights = "equal",
  type = "response"
)

cat("\n--- Mirror contrasts: Advice within Directed Motion (ΔSIU; collapsed over Synchrony) ---\n")
print(se_adv_by_dm)

cat("\n--- Mirror contrasts: Directed Motion within Advice (ΔSIU; collapsed over Synchrony) ---\n")
print(se_dm_by_adv)

cat("\n--- Mirror contrasts: Advice within Synchrony (ΔSIU; collapsed over Directed Motion) ---\n")
print(se_adv_by_syn)

cat("\n--- Synchrony within Advice (ΔSIU; Tukey; collapsed over Directed Motion) ---\n")
print(se_syn_by_adv)

cat("\n--- EMMs: Advice×Directed Motion (collapsed over Synchrony) ---\n")
print(emm_adv_dm_collapsed)

cat("\n--- EMMs: Advice×Synchrony (collapsed over Directed Motion) ---\n")
print(emm_adv_syn_collapsed)

# ==============================================================================
# 3) ANALYSIS 2: Confidence moderation (within–between decomposition)
#    Branch tests: conf_WP_z × Advice × Directed Motion vs conf_WP_z × Advice × Synchrony
# ==============================================================================

cat("\n====================\nANALYSIS 2: Confidence moderation\n====================\n")

# Baseline (structural) + covariates + BP confidence
m_base <- glmmTMB(
  s_sv ~ Advice * Directed_Motion * Synchrony + absA_z + conf_BP_z + (1 | participant),
  family = beta_family(link = "logit"),
  data = d
)

# Full moderation: add both branches
m_fullmod <- glmmTMB(
  s_sv ~ Advice * Directed_Motion * Synchrony +
    absA_z + conf_BP_z +
    conf_WP_z * Advice * Directed_Motion +
    conf_WP_z * Advice * Synchrony +
    (1 | participant),
  family = beta_family(link = "logit"),
  data = d
)

# A-only: conf_WP_z × Advice × DM
m_Aonly <- glmmTMB(
  s_sv ~ Advice * Directed_Motion * Synchrony +
    absA_z + conf_BP_z +
    conf_WP_z * Advice * Directed_Motion +
    (1 | participant),
  family = beta_family(link = "logit"),
  data = d
)

# B-only: conf_WP_z × Advice × Synchrony
m_Bonly <- glmmTMB(
  s_sv ~ Advice * Directed_Motion * Synchrony +
    absA_z + conf_BP_z +
    conf_WP_z * Advice * Synchrony +
    (1 | participant),
  family = beta_family(link = "logit"),
  data = d
)

# Model comparisons
print_lrt(m_base,  m_fullmod, "LRT: Baseline vs FULL moderation (A + B)")
print_lrt(m_Aonly, m_fullmod, "LRT: Is Branch B needed beyond A? (A-only vs Full)")
print_lrt(m_Bonly, m_fullmod, "LRT: Is Branch A needed beyond B? (B-only vs Full)")

p_overall <- anova(m_base,  m_fullmod)$`Pr(>Chisq)`[2]
p_needB   <- anova(m_Aonly, m_fullmod)$`Pr(>Chisq)`[2]
p_needA   <- anova(m_Bonly, m_fullmod)$`Pr(>Chisq)`[2]

cat("\n--- Key p-values ---\n")
