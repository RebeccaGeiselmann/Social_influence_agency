# ------------------------------------------------------------------------------
# Helper: Robustness SIU dataset maker (with random-trial counting)
# ------------------------------------------------------------------------------

make_siu_dataset <- function(dat,
                             tiny = 2,
                             eps  = 1e-8,
                             remove_gap_lt_25 = FALSE,
                             include_out_of_range_s = FALSE,
                             do_tiny_adjust = TRUE) {
  
  # base prep
  base <- dat %>%
    mutate(
      feedback_type_clean = tolower(trimws(as.character(feedback_type))),
      R1 = suppressWarnings(as.numeric(`slider_response1_2.response`)),
      R2 = suppressWarnings(as.numeric(`slider_response2_2.response`)),
      X  = suppressWarnings(as.numeric(agent_feedback)),
      
      Directed_Motion_raw = ifelse(
        str_detect(tolower(directed_motion), "present|\\bdp\\b"),
        "Present",
        ifelse(str_detect(tolower(directed_motion), "absent|\\bda\\b"),
               "Absent", NA_character_)
      ),
      
      Synchrony_raw = case_when(
        str_detect(tolower(synchrony), "high|\\bhs\\b|^h\\b")   ~ "High",
        str_detect(tolower(synchrony), "medium|\\bms\\b|^m\\b") ~ "Medium",
        str_detect(tolower(synchrony), "low|\\bls\\b|^l\\b")    ~ "Low",
        TRUE ~ NA_character_
      )
    )
  
  # keep only rows with finite numeric values ----
  df1 <- base %>%
    filter(is.finite(R1), is.finite(R2), is.finite(X))
  
  # --- COUNT random advice HERE (this is what you asked for) ---
  is_random <- function(a) tolower(trimws(as.character(a))) %in% c("random","rnd","rand")
  n_random_removed <- df1 %>% filter(is_random(feedback_type_clean)) %>% nrow()
  
  # drop random advice + map to Under/Over ----
  df2 <- df1 %>%
    filter(!is_random(feedback_type_clean)) %>%
    mutate(
      Advice_raw = case_when(
        feedback_type_clean %in% c("over","overestimator","overestimate")    ~ "Over",
        feedback_type_clean %in% c("under","underestimator","underestimate") ~ "Under",
        TRUE ~ NA_character_
      )
    ) %>%
    filter(!is.na(Advice_raw)) %>%
    filter(Advice_raw %in% c("Under","Over"))
  
  # coerce factors + compute gap ----
  si0 <- df2 %>%
    mutate(
      Advice          = factor(Advice_raw, levels = c("Under","Over")),
      Directed_Motion = factor(Directed_Motion_raw, levels = c("Present","Absent")),
      Synchrony       = factor(Synchrony_raw, levels = c("High","Medium","Low")),
      participant     = factor(participant_ID),
      gap             = abs(X - R1)
    ) %>%
    filter(!is.na(Directed_Motion), !is.na(Synchrony), !is.na(participant))
  
  # RC1: remove |X-R1| < 25 ----
  if (remove_gap_lt_25) {
    si0 <- si0 %>% filter(gap >= 25)
  }
  
  # compute movement flags (based on ORIGINAL R2, before any tiny-adjust)
  prep0 <- si0 %>%
    mutate(
      denom     = X - R1,
      num       = R2 - R1,
      equal_RX  = (R1 == X),
      
      toward    = sign(denom) * num >= 0,
      away      = sign(denom) * num <  0,
      overshoot = sign(denom) * (R2 - X) > 0,
      
      move_mag      = abs(num),
      overshoot_mag = abs(R2 - X),
      
      small_overall   = move_mag <= tiny,
      small_opposite  = away & (move_mag <= tiny),
      small_overshoot = overshoot & (overshoot_mag <= tiny)
    )
  
  # always drop X==R1 (advice impossible)
  prep0 <- prep0 %>% filter(!equal_RX)
  
  # apply or skip tiny adjustment
  prep <- prep0 %>%
    mutate(
      R2_adj = if (!do_tiny_adjust) {
        R2
      } else {
        case_when(
          small_overshoot ~ X,
          small_opposite  ~ R1,
          TRUE            ~ R2
        )
      },
      
      # SIU formula consistent with your original code
      s = (R2_adj - R1) / pmax(abs(denom), eps) * sign(denom),
      
      drop_neg = s < 0,
      drop_pos = s > 1
    )
  
  # RC2: include s<0 and s>1 (otherwise, enforce 0<=s<=1)
  if (!include_out_of_range_s) {
    prep <- prep %>% filter(!drop_neg, !drop_pos)
  }
  
  out <- prep %>%
    filter(is.finite(s)) %>%
    transmute(
      participant,
      participant_ID,
      condition,
      synchrony,
      directed_motion,
      movie_file,
      feedback_type,
      `slider_response1_2.response`,
      `slider_response1_2.rt`,
      agent_feedback,
      `slider_response2_2.response`,
      `slider_response2_2.rt`,
      R2_adj,
      s
    )
  
  stopifnot(nrow(out) > 0)
  
  # attach the random-removed count as an attribute (handy for printing once)
  attr(out, "n_random_removed") <- n_random_removed
  out
}

