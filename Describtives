# Helper: normalize emmeans CI names across versions 
normalize_ci <- function(df_emm, emm_obj = NULL) {
  nm <- names(df_emm)
  if ("lower.CL" %in% nm && "upper.CL" %in% nm) {
    df_emm <- dplyr::rename(df_emm, ymin = lower.CL, ymax = upper.CL)
  } else if ("asymp.LCL" %in% nm && "asymp.UCL" %in% nm) {
    df_emm <- dplyr::rename(df_emm, ymin = asymp.LCL, ymax = asymp.UCL)
  } else if ("LCL" %in% nm && "UCL" %in% nm) {
    df_emm <- dplyr::rename(df_emm, ymin = LCL, ymax = UCL)
  } else if (!is.null(emm_obj)) {
    ci_df <- as.data.frame(confint(emm_obj, type = "response"))
    if ("lower.CL" %in% names(ci_df))      ci_df <- dplyr::rename(ci_df, ymin = lower.CL,  ymax = upper.CL)
    else if ("asymp.LCL" %in% names(ci_df)) ci_df <- dplyr::rename(ci_df, ymin = asymp.LCL, ymax = asymp.UCL)
    else if ("LCL" %in% names(ci_df))       ci_df <- dplyr::rename(ci_df, ymin = LCL,      ymax = UCL)
    
    key_cols <- names(df_emm)[vapply(df_emm, is.factor, logical(1))]
    df_emm <- df_emm %>%
      dplyr::select(-dplyr::any_of(c("SE","df","lower.CL","upper.CL","asymp.LCL","asymp.UCL","LCL","UCL"))) %>%
      dplyr::left_join(ci_df %>% dplyr::select(dplyr::all_of(unique(c(key_cols, "response","ymin","ymax")))),
                       by = key_cols)
  }
  df_emm
}

