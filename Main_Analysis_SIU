# Analysis 1: Pre Social Influence Mediation Models 
# Binary Response ~ Synchrony * Directed Motion
# ------------------------------------------------------------------------------

infile <- file.path(output_dir, "all_participants_excluding_outliers_long.csv")
dat <- read_csv(infile, show_col_types = FALSE)

# Build binary DV and factors
df_bin <- dat %>%
  mutate(
    participant = factor(participant_ID),
    r1 = suppressWarnings(as.numeric(`slider_response1_2.response`)),
    Directed_Motion = factor(
      ifelse(grepl("present|\\bdp\\b", tolower(directed_motion)), "Present",
             ifelse(grepl("absent|\\bda\\b",  tolower(directed_motion)), "Absent", NA)),
      levels = c("Present","Absent")
    ),
    Synchrony = factor(dplyr::case_when(
      grepl("high|\\bhs\\b|^h\\b",   tolower(synchrony)) ~ "High",
      grepl("medium|\\bms\\b|^m\\b", tolower(synchrony)) ~ "Medium",
      grepl("low|\\bls\\b|^l\\b",    tolower(synchrony)) ~ "Low",
      TRUE ~ NA_character_
    ),
    levels = c("High","Medium","Low")
    ),
    # Yes=1 if r1>0, No=0 if r1<0; exact zero = NA (excluded)
    chase_bin = dplyr::case_when(
      is.finite(r1) & r1 >  0 ~ 1L,
      is.finite(r1) & r1 <  0 ~ 0L,
      is.finite(r1) & r1 == 0 ~ NA_integer_,
      TRUE ~ NA_integer_
    )
  ) %>%
  filter(!is.na(Directed_Motion), !is.na(Synchrony), !is.na(chase_bin)) %>%
  droplevels()

# Effect coding (sum-to-zero)
contrasts(df_bin$Directed_Motion) <- contr.sum(2)
contrasts(df_bin$Synchrony)       <- contr.sum(3)

# Fit mixed-effects logistic regression
m_logit_ec <- glmer(
  chase_bin ~ Synchrony * Directed_Motion + (1 | participant),
  data = df_bin,
  family = binomial(link = "logit"),
  control = glmerControl(optimizer = "bobyqa", optCtrl = list(maxfun = 1e5))
)

summary(m_logit_ec)

# Type III Wald χ² tests 
cat("\n--- Type III tests (Wald χ²) for main effects and interaction ---\n")
print(car::Anova(m_logit_ec, type = "III"))

# Block LRT for the interaction (does the 2-way add beyond main effects?)
m_main <- update(m_logit_ec, . ~ Synchrony + Directed_Motion + (1 | participant))
cat("\n--- Block test: does Synchrony×Directed Motion improve fit? (LRT) ---\n")
print(anova(m_main, m_logit_ec))  # Likelihood-ratio test

# Simple effects
# (A) Directed Motion within each Synchrony — log-odds differences (Holm for two levels)
emm_DM_within_S <- emmeans(m_logit_ec, ~ Directed_Motion | Synchrony, type = "link")
pairs_DM_logit <- pairs(emm_DM_within_S, adjust = "holm")

out_DM_logit <- summary(pairs_DM_logit, infer = TRUE, level = .95) %>%
  as.data.frame() %>%
  mutate(
    contrast = gsub("Present - Absent", "Present vs Absent", contrast, fixed = TRUE)
  ) %>%
  select(
    Synchrony,
    contrast,
    logOR = estimate,
    LCL = asymp.LCL,
    UCL = asymp.UCL,
    z = z.ratio,
    p = p.value
  )

cat("\nSimple effects — Directed Motion within each Synchrony — LOG-ODDS (log OR):\n")
print(out_DM_logit, row.names = FALSE)

# (B) Synchrony within each Directed Motion — log-odds differences (Tukey for 3 levels)
emm_S_within_DM <- emmeans(m_logit_ec, ~ Synchrony | Directed_Motion, type = "link")
pairs_S_logit <- pairs(emm_S_within_DM, adjust = "tukey")

out_S_logit <- summary(pairs_S_logit, infer = TRUE, level = .95) %>%
  as.data.frame() %>%
  select(
    Directed_Motion,
    contrast,
    logOR = estimate,
    LCL = asymp.LCL,
    UCL = asymp.UCL,
    z = z.ratio,
    p = p.value
  )

cat("\nSimple effects — Synchrony within each Directed Motion — LOG-ODDS (log OR):\n")
print(out_S_logit, row.names = FALSE)

# EMM: Probabilities by margins 
emm_DM_within_S_prob <- emmeans(m_logit_ec, ~ Directed_Motion | Synchrony, type = "response")
emm_S_within_DM_prob <- emmeans(m_logit_ec, ~ Synchrony | Directed_Motion, type = "response")

cat("\nDirected_Motion within Synchrony (probabilities):\n"); print(emm_DM_within_S_prob)
cat("\nSynchrony within Directed_Motion (probabilities):\n"); print(emm_S_within_DM_prob)

