cat("Need Branch B given A (A-only -> Full): p =", signif(p_needB, 4), "\n")
cat("Need Branch A given B (B-only -> Full): p =", signif(p_needA, 4), "\n")

# Choose target model (transparent rule)
alpha <- 0.05

if (!is.na(p_needA) && p_needA < alpha && !is.na(p_needB) && p_needB < alpha) {
  cat("\n>>> TARGET = FULL moderation (A + B)\n")
  m_target <- m_fullmod
} else if (!is.na(p_needA) && p_needA < alpha && (is.na(p_needB) || p_needB >= alpha)) {
  cat("\n>>> TARGET = A-only moderation (conf_WP_z × Advice × Directed Motion)\n")
  m_target <- m_Aonly
} else if (!is.na(p_needB) && p_needB < alpha && (is.na(p_needA) || p_needA >= alpha)) {
  cat("\n>>> TARGET = B-only moderation (conf_WP_z × Advice × Synchrony)\n")
  m_target <- m_Bonly
} else {
  cat("\n>>> TARGET = Baseline (no supported moderation branch)\n")
  m_target <- m_base
}

# Inference on TARGET model
cat("\n--- Type III Wald χ² tests (TARGET) ---\n")
print(car::Anova(m_target, type = "III"))

cat("\n--- Fixed effects (TARGET; logit scale) ---\n")
print(summary(m_target))

# ==============================================================================
# 4) Probing / EMM tables for TARGET model (only if conf_WP_z is present)
# ==============================================================================

coef_names <- names(fixef(m_target)$cond)
has_confWP <- any(grepl("conf_WP_z", coef_names))

if (!has_confWP) {
  cat("\n(No within-person confidence term in TARGET -> skipping confidence probing.)\n")
} else {
  
  # Confidence levels: -1 SD, mean, +1 SD on z-scale
  conf_levels <- c(low = -1, mean = 0, high = 1)
  
  # Hold covariates at mean
  at_cov <- list(absA_z = 0, conf_BP_z = 0)
  
  # Contrast direction definitions
  # Advice: Over - Under (levels are Under, Over)
  c_over_under <- list("Over - Under" = c(-1, 1))
