# ------------------------------------------------------------
# Trial-level exclusion 2 (recommended): within-participant × condition Tukey
# compute Tukey bounds on TRIAL RTs, per participant × condition
# ------------------------------------------------------------

# Ensure rt column exists for the Tukey code below
no_fast <- no_fast %>%
  mutate(
    participant = as.integer(participant),
    synchrony = tolower(as.character(synchrony)),
    directed_motion = tolower(as.character(directed_motion)),
    rt = suppressWarnings(as.numeric(slider_response1_2.rt))
  )

bounds_wp <- no_fast %>%
  group_by(participant, synchrony, directed_motion) %>%
  summarise(
    Q1 = quantile(rt, 0.25, na.rm = TRUE),
    Q3 = quantile(rt, 0.75, na.rm = TRUE),
    IQR = Q3 - Q1,
    Lower = Q1 - 1.5 * IQR,
    Upper = Q3 + 1.5 * IQR,
    n_trials = sum(!is.na(rt)),
    .groups = "drop"
  )

write_csv(bounds_wp, file.path(output_dir, "rt1_tukey_bounds_within_participant_condition.csv"))

# Join bounds back to trials and flag outliers
trial_flagged <- no_fast %>%
  left_join(bounds_wp, by = c("participant", "synchrony", "directed_motion")) %>%
  mutate(
    is_outlier_lower = !is.na(rt) & !is.na(Lower) & rt < Lower,
    is_outlier_upper = !is.na(rt) & !is.na(Upper) & rt > Upper,
    is_outlier       = is_outlier_lower | is_outlier_upper
  )

# ------------------------------------------------------------
# Count outlier trials per participant × condition
# ------------------------------------------------------------
outlier_counts_by_pc <- trial_flagged %>%
  group_by(participant, synchrony, directed_motion) %>%
  summarise(
    n_trials    = sum(!is.na(rt)),
    n_below     = sum(is_outlier_lower, na.rm = TRUE),
    n_above     = sum(is_outlier_upper, na.rm = TRUE),
    n_outlier   = sum(is_outlier,       na.rm = TRUE),
    prop_outlier = if_else(n_trials > 0, n_outlier / n_trials, NA_real_),
    .groups = "drop"
  ) %>%
  arrange(synchrony, directed_motion, desc(n_outlier))

overall_by_condition <- outlier_counts_by_pc %>%
  group_by(synchrony, directed_motion) %>%
  summarise(
    total_trials   = sum(n_trials, na.rm = TRUE),
    total_outliers = sum(n_outlier, na.rm = TRUE),
    prop_outliers  = if_else(total_trials > 0, total_outliers / total_trials, NA_real_),
    .groups = "drop"
  )

totals_by_participant <- outlier_counts_by_pc %>%
  group_by(participant) %>%
  summarise(
    n_trials     = sum(n_trials, na.rm = TRUE),
    n_outlier    = sum(n_outlier, na.rm = TRUE),
    prop_outlier = if_else(n_trials > 0, n_outlier / n_trials, NA_real_),
    .groups = "drop"
  ) %>%
  arrange(desc(prop_outlier), desc(n_outlier))

