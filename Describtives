  case_when(
    str_detect(x, "high|\\bhs\\b|^h\\b")   ~ "High",
    str_detect(x, "medium|\\bms\\b|^m\\b") ~ "Medium",
    str_detect(x, "low|\\bls\\b|^l\\b")    ~ "Low",
    TRUE ~ NA_character_
  )
}
rec_dir <- function(x){
  x <- tolower(trimws(as.character(x)))
  case_when(
    str_detect(x, "present|\\bdp\\b") ~ "Present",
    str_detect(x, "absent|\\bda\\b")  ~ "Absent",
    TRUE ~ NA_character_
  )
}

