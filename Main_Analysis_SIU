infile <- file.path(output_dir, "all_participants_excluding_outliers_long.csv")
dat <- read_csv(infile, show_col_types = FALSE)

## Build confidence-strength outcome (0..1), apply SV squeeze
dfc <- dat %>%
  mutate(
    participant = factor(participant_ID),
    r1   = suppressWarnings(as.numeric(`slider_response1_2.response`)),
    conf = pmin(pmax(abs(r1)/100, 0), 1),  # 0..1
    Directed_Motion = factor(
      ifelse(str_detect(tolower(directed_motion), "present|\\bdp\\b"), "Present", "Absent"),
      levels = c("Present","Absent")
    ),
    Synchrony = factor(case_when(
      str_detect(tolower(synchrony), "high|\\bhs\\b|^h\\b")   ~ "High",
      str_detect(tolower(synchrony), "medium|\\bms\\b|^m\\b") ~ "Medium",
      str_detect(tolower(synchrony), "low|\\bls\\b|^l\\b")    ~ "Low",
      TRUE ~ NA_character_
    ), levels = c("High","Medium","Low"))
  ) %>%
  filter(!is.na(Directed_Motion), !is.na(Synchrony), is.finite(conf)) %>%
  droplevels()

N <- nrow(dfc)
dfc <- dfc %>% mutate(conf_sv = (conf * (N - 1) + 0.5) / N)  # Smithson–Verkuilen

## Effect coding (sum-to-zero) — set on the columns used in the model
contrasts(dfc$Directed_Motion) <- contr.sum(2)  # column named "Directed_Motion1"
contrasts(dfc$Synchrony)       <- contr.sum(3)  # columns "Synchrony1","Synchrony2"

## Beta GLMM with logit link
m_conf <- glmmTMB(
  conf_sv ~ Synchrony * Directed_Motion + (1 | participant),
  family = beta_family(link = "logit"),
  data = dfc
)
summary(m_conf)

#  Type III Wald χ² tests for main effects and interaction
cat("\n--- Type III tests (Wald χ²) for main effects and interaction ---\n")
print(car::Anova(m_conf, type = "III"))

# Block LRT: does the Synchrony × Directed_Motion interaction improve fit?
m_conf_main <- glmmTMB(
  conf_sv ~ Synchrony + Directed_Motion + (1 | participant),
  family = beta_family(link = "logit"),
  data = dfc
)
cat("\n--- Block test: does Synchrony×Directed Motion improve fit? (LRT) ---\n")
print(anova(m_conf_main, m_conf))  # interaction vs main-effects-only

# Simple effects 
# A) Directed Motion within each level of Synchrony

