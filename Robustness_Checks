# ==============================================================================
# Robustness checks for SIU analyses (Target Model 1 + Target Model 2)
# - Runs the SAME two target models on multiple robustness datasets
# - Prints: omnibus Type III tests, EMMs, and simple effects
# - Handles the "include out-of-range s" dataset by clamping into [0,1]
#   (beta regression requires values in (0,1) after SV squeeze)
# ==============================================================================

# ==============================================================
# PATH
# ==============================================================

output_dir <- "Output"

# ==============================================================
# HELPER FUNCTIONS
# ==============================================================

# Smithson–Verkuilen squeeze
sv_squeeze_N <- function(x, N) {
  (x * (N - 1) + 0.5) / N
}

# Pairwise differences on RESPONSE scale (Δ SIU)
pairs_delta <- function(emm, by = NULL, adjust = "holm") {
  pairs(regrid(emm, transform = "response"), by = by, adjust = adjust)
}

mean0 <- function(x) mean(x, na.rm = TRUE)

# ==============================================================
# CORE RUNNER
# ==============================================================

run_siu_targets <- function(output_dir,
                            filename,
                            clamp_out_of_range = FALSE,
                            verbose = TRUE) {
  
  datafile <- file.path(output_dir, filename)
  
  if (verbose) {
    cat("\n============================================================\n")
    cat("ROBUSTNESS RUN ON:", filename, "\n")
    cat("Clamp out-of-range s:", clamp_out_of_range, "\n")
    cat("============================================================\n")
  }
  
  # ------------------------------------------------------------
  # LOAD + CLEAN
  # ------------------------------------------------------------
  
  d <- read_csv(datafile, show_col_types = FALSE) %>%
    rename(
      R1 = slider_response1_2.response,
      X  = agent_feedback,
      R2 = slider_response2_2.response,
      s  = s
    ) %>%
    mutate(
      participant = factor(participant),
      
      # clean raw strings
      dm_clean  = str_to_lower(str_trim(directed_motion)),
      syn_clean = str_to_lower(str_trim(synchrony)),
      fb_clean  = str_to_lower(str_trim(feedback_type)),
      
      Directed_Motion = case_when(
        dm_clean %in% c("present","dp","directed_present") ~ "Present",
        dm_clean %in% c("absent","da","directed_absent")   ~ "Absent",
        TRUE ~ NA_character_
      ),
      
      Synchrony = case_when(
        syn_clean %in% c("high","hs")   ~ "High",
        syn_clean %in% c("medium","ms") ~ "Medium",
        syn_clean %in% c("low","ls")    ~ "Low",
        TRUE ~ NA_character_
      ),
      
      Advice = case_when(
        fb_clean %in% c("under","underestimate","underestimator") ~ "Under",
        fb_clean %in% c("over","overestimate","overestimator")    ~ "Over",
        TRUE ~ NA_character_
      ),
      
      Directed_Motion = factor(Directed_Motion, levels = c("Present","Absent")),
      Synchrony       = factor(Synchrony, levels = c("High","Medium","Low")),
      Advice          = factor(Advice, levels = c("Under","Over")),
      
      A    = X - R1,
      absA = abs(A)
    ) %>%
    filter(
      is.finite(s),
      !is.na(Advice),
      !is.na(Directed_Motion),
      !is.na(Synchrony),
      is.finite(absA)
    ) %>%
    droplevels()
  
  # Optional clamp for include_out_of_range dataset
  if (clamp_out_of_range) {
    d <- d %>% mutate(s = pmin(pmax(s, 0), 1))
  }
  
  # SV squeeze using dataset N
  N <- nrow(d)
  d <- d %>% mutate(s_sv = sv_squeeze_N(s, N))
  
  # Sum coding
  contrasts(d$Advice)          <- contr.sum(2)
  contrasts(d$Directed_Motion) <- contr.sum(2)
  contrasts(d$Synchrony)       <- contr.sum(3)
  
  # ============================================================
  # TARGET MODEL 1
  # ============================================================
  
  cat("\n--- TARGET MODEL 1 ---\n")
  
  m1 <- glmmTMB(
    s_sv ~ Advice * Directed_Motion * Synchrony + absA + (1 | participant),
    family = beta_family(link = "logit"),
    data = d
  )
  
  cat("\nOmnibus Type III Wald χ²:\n")
  print(car::Anova(m1, type = "III"))
  
  # SAFE EMM wrapper (fixes your crash)
  emm1 <- function(specs, ...) {
    emmeans(
      m1, specs,
      ...,
      cov.reduce = list(absA = mean),
      cov.keep = 0
    )
  }
  
  cat("\nEMMs (full 2×2×3 table):\n")
  print(emm1(~ Advice * Directed_Motion * Synchrony, type = "response"))
  
  cat("\nSimple effects: Advice within DM × Sync:\n")
  print(summary(
    pairs_delta(
      emm1(~ Advice | Directed_Motion * Synchrony, type = "response"),
      by = c("Directed_Motion","Synchrony")
    ),
    infer = TRUE
  ))
  
  # ============================================================
  # TARGET MODEL 2 (Confidence moderation)
  # ============================================================
  
  cat("\n--- TARGET MODEL 2 ---\n")
  
  d2 <- d %>%
    mutate(
      conf_strength = pmin(pmax(abs(R1)/100, 0), 1)
    ) %>%
    group_by(participant) %>%
    mutate(
      conf_mean_id = mean(conf_strength, na.rm = TRUE),
      conf_WP      = conf_strength - conf_mean_id,
      conf_BP      = conf_mean_id
    ) %>%
    ungroup() %>%
    mutate(
      absA_z    = as.numeric(scale(absA)),
      conf_BP_z = as.numeric(scale(conf_BP))
    )
  
  contrasts(d2$Advice)          <- contr.sum(2)
  contrasts(d2$Directed_Motion) <- contr.sum(2)
  contrasts(d2$Synchrony)       <- contr.sum(3)
  
  m2 <- glmmTMB(
    s_sv ~ Advice * Directed_Motion * Synchrony +
      absA_z + conf_BP_z +
      conf_WP * Advice * Directed_Motion +
      (1 | participant),
    family = beta_family(link = "logit"),
    data = d2
  )
  
  cat("\nOmnibus Type III Wald χ²:\n")
  print(car::Anova(m2, type = "III"))
  
  emm2 <- function(specs, ...) {
    emmeans(
      m2, specs,
      ...,
      cov.reduce = list(absA_z = mean, conf_BP_z = mean),
      cov.keep = 0
    )
  }
  
  sd_confWP <- sd(d2$conf_WP, na.rm = TRUE)
  conf_levels <- c(low = -sd_confWP, mean = 0, high = sd_confWP)
  
  cat("\nEMMs: Advice × Directed Motion at ±1 SD confidence:\n")
  print(
    emm2(
      ~ Advice * Directed_Motion | conf_WP,
      at = list(conf_WP = conf_levels, absA_z = 0, conf_BP_z = 0),
      type = "response"
    )
  )
  
  invisible(list(m1 = m1, m2 = m2))
}

