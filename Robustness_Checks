summarize_variant <- function(df, name) {
  cat("\n---", name, "---\n")
  cat("Trials:", nrow(df), " | Participants:", dplyr::n_distinct(df$participant), "\n")
  cat("s summary:\n")
  print(summary(df$s))
  cat("Prop s==0:", mean(df$s == 0), " | Prop s==1:", mean(df$s == 1), "\n")
  invisible(NULL)
}

summarize_variant(siu_clean_original,     "ORIGINAL (0<=s<=1, tiny adjust ON, keep gap<25)")
summarize_variant(siu_clean_gap25,        "RC1 (0<=s<=1, tiny adjust ON, gap>=25)")
summarize_variant(siu_include_outofrange, "RC2 (include s<0 and s>1, tiny adjust ON)")
summarize_variant(siu_no_tiny_adjust,     "RC3 (0<=s<=1, tiny adjust OFF, keep gap<25)")

