# ------------------------------------------------------------------------------
# ANALYSIS 1: SOCIAL INFORMATION USE
# MODEL 1: Advice × Directed Motion × Synchrony
# ------------------------------------------------------------------------------

# Research question:
# Does the extent to which participants use social advice (SIU) depend on:
#   (a) advice direction (Under vs Over),
#   (b) stimulus features (Directed Motion, Synchrony),
#   and (c) their interactions?
# ------------------------------------------------------------------------------

# ------------------------------------------------------------------------------
# Data preparation
# ------------------------------------------------------------------------------

# Read pre-cleaned trial-level dataset
d <- read_csv(file.path(output_dir, "siu_trials_clean.csv"), show_col_types = FALSE) %>%
  rename(
    R1 = slider_response1_2.response,  # initial estimate
    X  = agent_feedback,               # social (advice) value
    R2 = slider_response2_2.response,  # revised estimate
    R2_adj = R2_adj,                   # adjusted revision (cleaned)
    s  = s                             # social information use index
  ) %>%
  mutate(
    participant = factor(participant),
    Directed_Motion = factor(str_to_title(directed_motion),
                             levels = c("Present","Absent")),
    Synchrony       = factor(str_to_title(synchrony),
                             levels = c("High","Medium","Low")),
    Advice          = factor(str_to_lower(feedback_type),
                             levels = c("under","over"),
                             labels = c("Under","Over")),
    A    = X - R1,       # signed advice magnitude
    absA = abs(A)        # absolute advice magnitude (covariate)
  ) %>%
  filter(is.finite(s))   # remove any missing/non-finite SIU values

# ------------------------------------------------------------------------------
# Transformation and coding
# ------------------------------------------------------------------------------

# Apply Smithson–Verkuilen squeeze transformation to keep s in (0,1)
N <- nrow(d)
d <- d %>% mutate(s_sv = (s * (N - 1) + 0.5) / N)

# Set sum-to-zero contrasts (required for Type III tests)
contrasts(d$Advice)          <- contr.sum(2)
contrasts(d$Directed_Motion) <- contr.sum(2)
contrasts(d$Synchrony)       <- contr.sum(3)

# ------------------------------------------------------------------------------
# Model fitting: hierarchical (nested) structure
# ------------------------------------------------------------------------------

# Baseline model: only advice direction and covariate (no stimulus effects)
m_noStim <- glmmTMB(
  s_sv ~ Advice + absA + (1 | participant),
  family = beta_family(link = "logit"),
  data = d
)

# Add main and interaction effects of Directed Motion and Synchrony
m_addStim <- glmmTMB(
  s_sv ~ Advice + Directed_Motion * Synchrony + absA + (1 | participant),
  family = beta_family(link = "logit"),
  data = d
)

# Full model: include all Advice × Stimulus interactions
m_full <- glmmTMB(
  s_sv ~ Advice * Directed_Motion * Synchrony + absA + (1 | participant),
  family = beta_family(link = "logit"),
  data = d
)

# ------------------------------------------------------------------------------
# Hierarchical model comparisons (likelihood-ratio block tests)
# ------------------------------------------------------------------------------

# Step 1: Does adding Advice Direction improve model fit?
m_noAdvice <- glmmTMB(
  s_sv ~ absA + (1|participant),
  family = beta_family(link = "logit"),
  data = d
)

m_adviceOnly <- update(m_noAdvice, . ~ . + Advice)
anova(m_noAdvice, m_adviceOnly)  # LRT for global (main) effect of Advice

# Step 2: Do stimulus features improve model fit?
cat("\n--- Block test: Stimulus (Directed Motion, Synchrony, Directed×Synchrony) ---\n")
print(anova(m_noStim, m_addStim))

# Step 3: Do Advice × Stimulus interactions improve model fit?
cat("\n--- Block test: Advice×Stimulus interactions ---\n")
print(anova(m_addStim, m_full))


# ------------------------------------------------------------------------------
# Full model inference
# ------------------------------------------------------------------------------

# Inspect fixed-effect estimates (logit scale)
summary(m_full)

# Type III Wald χ² tests for main and interaction effects
cat("\n--- Type III tests from the full model (sum coding) ---\n")
print(car::Anova(m_full, type = "III"))

# Likelihood-ratio test for the 3-way interaction
m_no3 <- update(m_full, . ~ . - Advice:Directed_Motion:Synchrony)
anova(m_no3, m_full)


# ------------------------------------------------------------------------------
# Estimated marginal means and simple-effects decomposition
# ------------------------------------------------------------------------------

# Obtain estimated means (response scale, 0–1) for all cells
emm_full <- emmeans(m_full, ~ Advice * Directed_Motion * Synchrony, type = "response")
print(emm_full)

# Simple effects of Advice within each Directed×Synchrony cell
se_advice <- pairs(emm_full, by = c("Directed_Motion","Synchrony"), adjust = "holm")
