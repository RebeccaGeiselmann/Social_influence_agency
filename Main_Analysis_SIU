  )
  cat("\n--- EMMs (Figure 4 style): Advice×Directed Motion by confidence (avg over Synchrony) ---\n")
  print(em_fig4)
  
  # ---------------------------
  # (B) Simple effects: Advice within Directed Motion at each confidence level
  #     (Over - Under)
  # ---------------------------
  em_adv_byDM <- emmeans(
    m_target,
    ~ Advice | Directed_Motion * conf_WP_z,
    at = c(list(conf_WP_z = conf_levels), at_cov),
    type = "response",
    weights = "equal"
  )
  
  se_adv_byDM <- contrast(
    regrid(em_adv_byDM, transform = "response"),
    method = c_over_under,
    by = c("Directed_Motion", "conf_WP_z")
  )
  
  cat("\n--- Simple effects: Advice (Over-Under) within Directed Motion × Confidence (ΔSIU) ---\n")
  print(summary(se_adv_byDM, infer = TRUE))
  
  # ---------------------------
  # (C) Simple effects: Directed Motion within Advice at each confidence level
  #     (Absent - Present)
  # ---------------------------
  em_DM_byAdv <- emmeans(
    m_target,
    ~ Directed_Motion | Advice * conf_WP_z,
    at = c(list(conf_WP_z = conf_levels), at_cov),
    type = "response",
    weights = "equal"
  )
  
  se_DM_byAdv <- contrast(
    regrid(em_DM_byAdv, transform = "response"),
    method = c_abs_pres,
    by = c("Advice", "conf_WP_z")
  )
  
  cat("\n--- Simple effects: Directed Motion (Absent-Present) within Advice × Confidence (ΔSIU) ---\n")
  print(summary(se_DM_byAdv, infer = TRUE))
  
  # ---------------------------
  # (D) Simple slopes of within-person confidence within each Advice × DM cell
  #     (model/logit scale)
  # ---------------------------
  em_conf <- emtrends(
    m_target,
    ~ Advice * Directed_Motion,
    var = "conf_WP_z",
    at = at_cov
  )
  
  cat("\n--- Simple slopes: effect of conf_WP_z within each Advice × Directed Motion cell (logit scale) ---\n")
  print(em_conf)
  
  cat("\n--- Differences in confidence slopes: Advice effect on slope (within Directed Motion) ---\n")
  print(pairs(em_conf, by = "Directed_Motion"))
  
  cat("\n--- Differences in confidence slopes: Directed Motion effect on slope (within Advice) ---\n")
  print(pairs(em_conf, by = "Advice"))
  
  # ---------------------------
  # (E) Optional: EMMs collapsed (Advice×DM) at each confidence level
  #     (Useful if you want a supplement table that mirrors your structural EMMs)
  # ---------------------------
  em_adv_dm_by_conf <- emmeans(
    m_target,
    ~ Advice * Directed_Motion | conf_WP_z,
    at = c(list(conf_WP_z = conf_levels), at_cov),
    type = "response",
    weights = "equal"
  )
  cat("\n--- EMMs: Advice×Directed Motion at each confidence level (avg over Synchrony) ---\n")
  print(em_adv_dm_by_conf)
}

