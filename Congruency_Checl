  geom_line(linewidth = 1.2, color = "purple") +
  geom_point(size = 3.2, color = "purple") +
  # Dotted reference line at 0.50
  geom_hline(yintercept = 0.50, linetype = 2, color = "grey60") +
  scale_x_discrete(labels = c(
    "Under" = "Underestimation",
    "Over"  = "Overestimation"
  )) +
  scale_y_continuous(
    limits = c(0, 1),
    breaks = c(0, 0.25, 0.50, 0.75, 1.00)
