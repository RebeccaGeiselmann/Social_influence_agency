r1_col <- intersect(names(dat), r1_candidates)
if (length(r1_col) == 0) stop("No R1 column found. Expected one of: ", paste(r1_candidates, collapse=", "))
r1_col <- r1_col[1]

# Build analysis dataframe (same mappings)
s_df <- dat %>%
  mutate(
    Advice_Direction = case_when(
      str_trim(tolower(as.character(feedback_type))) == "over"  ~ "Overestimate",
      str_trim(tolower(as.character(feedback_type))) == "under" ~ "Underestimate",
      TRUE ~ NA_character_
    ),
    Directed_Motion = case_when(
      str_detect(tolower(as.character(directed_motion)), "present|\\bdp\\b") ~ "Present",
      str_detect(tolower(as.character(directed_motion)), "absent|\\bda\\b")  ~ "Absent",
      TRUE ~ NA_character_
    ),
    participant = factor(participant_ID),
    s  = as.numeric(s),
    r1 = as.numeric(.data[[r1_col]])
  ) %>%
  filter(!is.na(Advice_Direction), !is.na(Directed_Motion), is.finite(s), is.finite(r1)) %>%
  mutate(
    Advice_Direction = factor(Advice_Direction, levels = c("Overestimate","Underestimate")),
    Directed_Motion  = factor(Directed_Motion,  levels = c("Present","Absent"))
  )

# Confidence: absolute R1 → 0..1, then within-person centered 
s_df <- s_df %>%
  mutate(conf_raw = pmin(1, pmax(0, abs(r1)/100))) %>%
  group_by(participant) %>%
  mutate(conf_wp = conf_raw - mean(conf_raw, na.rm = TRUE)) %>%
  ungroup()

# Bin confidence into Low / Medium / High using ±1 SD 
conf_mu <- mean(s_df$conf_wp, na.rm = TRUE)
conf_sd <- sd(s_df$conf_wp,   na.rm = TRUE)

s_df <- s_df %>%
  mutate(
    conf_bin = case_when(
      conf_wp <= (conf_mu - conf_sd) ~ "Low (−1 SD)",
      conf_wp >= (conf_mu + conf_sd) ~ "High (+1 SD)",
      TRUE                           ~ "Confidence\nMedium (Mean)"
    ),
    conf_bin = factor(conf_bin, levels = c("Low (−1 SD)", "Confidence\nMedium (Mean)", "High (+1 SD)"))
  )

# Participant means within each cell (RAW) 
pmeans <- s_df %>%
  group_by(participant, Advice_Direction, Directed_Motion, conf_bin) %>%
  summarise(p_mean = mean(s, na.rm = TRUE), .groups = "drop")

