# ------------------------------------------------------------------------------
# Social Influence Exclusions
# ------------------------------------------------------------------------------

# Exclusion Criteria: 
# 1) Exclude feedback_type == "random"
# 2) Drop R1 == X
# 3) Adjust R2:
#    (i) tiny overshoot (|R2−X| ≤ 2)  → R2_adj = X
#    (ii) tiny move in the opposite direction (≤ 2 units beyond R1) → R2_adj = R1
#    else R2_adj = R2
# 4) Compute s = (R2_adj − R1) / (X − R1); keep only 0 ≤ s ≤ 1
# 5) Keep all |X − R1| magnitudes (no gap-based exclusions)


infile <- file.path(output_dir, "all_participants_excluding_outliers_long.csv")
dat <- read_csv(infile, show_col_types = FALSE)

# Parameters 
tiny <- 2      # units on the slider considered "tiny"
eps  <- 1e-8   # numerical safety to avoid 0 division

# Base prep 

base <- dat %>%
  mutate(
    feedback_type_clean = tolower(trimws(as.character(feedback_type))),
    R1 = suppressWarnings(as.numeric(`slider_response1_2.response`)),
    R2 = suppressWarnings(as.numeric(`slider_response2_2.response`)),
    X  = suppressWarnings(as.numeric(agent_feedback)),
    Advice_raw = case_when(
      feedback_type_clean %in% c("over","overestimator","overestimate")    ~ "Over",
      feedback_type_clean %in% c("under","underestimator","underestimate") ~ "Under",
      TRUE ~ feedback_type_clean
    ),
    Directed_Motion_raw = ifelse(str_detect(tolower(directed_motion), "present|dp"), "Present", "Absent"),
    Synchrony_raw = case_when(
      str_detect(tolower(synchrony), "high|hs|^h\\b")   ~ "High",
      str_detect(tolower(synchrony), "medium|ms|^m\\b") ~ "Medium",
      str_detect(tolower(synchrony), "low|ls|^l\\b")    ~ "Low",
      TRUE ~ as.character(synchrony)
    )
  )

# Helper: select transparent report columns
select_report_cols <- function(df) {
  keep <- intersect(c(
    names(dat),
    "R1","R2","X","R2_adj","s",
    "Advice_raw","Directed_Motion_raw","Synchrony_raw"
  ), names(df))
  df %>% select(all_of(keep))
}

# Containers to log exclusions/flags
ex_log <- list()
flag_log <- list()

# Exclusion: non-finite R1/R2/X
ex_nonfinite <- base %>%
  filter(!is.finite(R1) | !is.finite(R2) | !is.finite(X)) %>%
  mutate(exclusion_reason = "Non-finite R1/R2/X")
ex_log[["nonfinite"]] <- select_report_cols(ex_nonfinite)

df1 <- base %>% filter(is.finite(R1), is.finite(R2), is.finite(X))

# Exclusion: random advice
is_random <- function(a) tolower(a) %in% c("random","rnd","rand")
ex_random <- df1 %>%
  filter(is_random(Advice_raw)) %>%
  mutate(exclusion_reason = "Random advice")
ex_log[["random"]] <- select_report_cols(ex_random)

df2 <- df1 %>% filter(is.na(Advice_raw) | !is_random(Advice_raw))

#  Coerce factors for the kept stream
si0 <- df2 %>%
  mutate(
    Advice          = factor(Advice_raw, levels = c("Under","Over")),
    Directed_Motion = factor(Directed_Motion_raw, levels = c("Present","Absent")),
    Synchrony       = factor(Synchrony_raw, levels = c("High","Medium","Low")),
    participant     = factor(participant_ID)
  )

# Report two specific counts you asked about (on si0)
flag_df <- si0 %>%
  mutate(gap = abs(X - R1),
         reason_equalRX = (R1 == X),
         reason_gaplt25 = (gap < 25))

ex_equalRX_view <- flag_df %>% filter(reason_equalRX)   # overlaps with gap<25
ex_gaplt25_view <- flag_df %>% filter(reason_gaplt25)

# Print counts 
cat("\nSpecific reasons (computed on si0, before SIU adjustments and s-filter):\n")
cat("  (1) X == R1:                  ", nrow(ex_equalRX_view), "\n")
cat("  (2) |X - R1| < 25:            ", nrow(ex_gaplt25_view), "\n")
cat("      Overlap of (1) and (2):   ",
    nrow(flag_df %>% filter(reason_equalRX & reason_gaplt25)), "\n")
cat("      Union (unique rows):      ",
    nrow(flag_df %>% filter(reason_equalRX | reason_gaplt25)),  "\n")


# Prep, flags, and adjustments
# tiny overall = flagged only (no adjustment)
# tiny opposite / tiny overshoot = adjusted
prep0 <- si0 %>%
  mutate(
    denom     = X - R1,
    num       = R2 - R1,
    equal_RX  = (R1 == X),                    # exclusion below
    toward    = sign(denom) * num >= 0,
    away      = sign(denom) * num <  0,
    overshoot = sign(denom) * (R2 - X) > 0,
    
    move_mag        = abs(num),
    overshoot_mag   = abs(R2 - X),
    
    small_overall   = move_mag <= tiny,
    small_opposite  = away & (move_mag <= tiny),
    small_overshoot = overshoot & (overshoot_mag <= tiny)
  )

# Exclusion: X == R1 (advice impossible)
ex_equal <- prep0 %>%
  filter(equal_RX) %>%
  mutate(exclusion_reason = "X == R1 (advice impossible)")
ex_log[["equalRX"]] <- select_report_cols(ex_equal)

prep <- prep0 %>%
  filter(!equal_RX) %>%
  mutate(
    R2_adj = case_when(
      small_overshoot ~ X,   # adjust tiny overshoot
      small_opposite  ~ R1,  # adjust tiny opposite
      TRUE            ~ R2   # tiny overall: no adjustment
    ),
    s = (R2_adj - R1) / pmax(abs(denom), eps) * sign(denom),
    drop_neg = s < 0,   # big opposite
    drop_pos = s > 1    # big overshoot
  )


# Exclusions after s: s<0 or s>1
ex_sneg <- prep %>% filter(drop_neg) %>% mutate(exclusion_reason = "s < 0 (big opposite)")
ex_spos <- prep %>% filter(drop_pos) %>% mutate(exclusion_reason = "s > 1 (big overshoot)")
ex_log[["s_neg"]] <- select_report_cols(ex_sneg)
ex_log[["s_pos"]] <- select_report_cols(ex_spos)


# Final kept trials for SIU (keep original structure)
siu_clean <- prep %>%
  filter(!drop_neg, !drop_pos, is.finite(s)) %>%
  select(
    participant,
    participant_ID,
    condition,
    synchrony,
    directed_motion,
    movie_file,
    feedback_type,
    `slider_response1_2.response`,
    `slider_response1_2.rt`,
    agent_feedback,
    `slider_response2_2.response`,
    `slider_response2_2.rt`,
    R2_adj,
    s
  )

stopifnot(nrow(siu_clean) > 0)

write_csv(siu_clean, file.path(output_dir, "siu_trials_clean.csv"))
cat("\nSaved SIU-clean trials to:",
    file.path(output_dir, "siu_trials_clean.csv"), "\n")

# Summaries (printed)
adj_summary <- prep %>%
  transmute(reason = case_when(
    small_overshoot                    ~ "Adjusted: tiny overshoot (R2:=X)",
    small_opposite                     ~ "Adjusted: tiny opposite (R2:=R1)",
    small_overall & !small_opposite    ~ "Flagged: tiny overall (no adjustment)",
    TRUE                               ~ "No small adjustment"
  )) %>%
  count(reason) %>%
  arrange(desc(n))

keepdrop_summary <- prep %>%
  transmute(reason = case_when(
    drop_neg ~ "Dropped: s<0 (big opposite)",
    drop_pos ~ "Dropped: s>1 (big overshoot)",
    TRUE     ~ "Kept: 0≤s≤1"
  )) %>%
  count(reason) %>%
  arrange(desc(n))

by_advice <- prep %>%
  filter(!drop_neg, !drop_pos, is.finite(s)) %>%
  count(Advice, Directed_Motion, Synchrony) %>%
  arrange(Advice, Directed_Motion, Synchrony)

cat("\nAdjustment summary:\n"); print(adj_summary)
cat("\nPost-adjustment keep/drop summary:\n"); print(keepdrop_summary)
cat("\nFinal kept trials by Advice × Directed × Synchrony:\n"); print(by_advice)
