  group_by(Advice_Direction, Directed_Motion, conf_bin) %>%
  summarise(
    n_part = n(),
    mean_s = mean(p_mean, na.rm = TRUE),
    SE     = sd(p_mean,  na.rm = TRUE) / sqrt(n_part),
