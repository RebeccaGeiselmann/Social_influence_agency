    Synchrony       = factor(str_to_title(synchrony),       levels = c("High","Medium","Low")),
    Advice          = factor(str_to_lower(feedback_type),
                             levels = c("under","over"),
                             labels = c("Under","Over")),
    A    = X - R1,
    absA = abs(A),
    
    # Your confidence proxy (as used previously)
    conf_strength = pmin(pmax(abs(R1) / 100, 0), 1)
  ) %>%
  group_by(participant) %>%
  mutate(
    conf_mean_id = mean(conf_strength, na.rm = TRUE),
    conf_WP      = conf_strength - conf_mean_id,   # within-person deviation
    conf_BP      = conf_mean_id                    # between-person mean confidence
  ) %>%
  ungroup() %>%
  mutate(
    absA_z    = as.numeric(scale(absA)),
    conf_BP_z = as.numeric(scale(conf_BP))
  ) %>%
  filter(is.finite(s), is.finite(absA_z), is.finite(conf_WP), is.finite(conf_BP_z))

# ------------------------------------------------------------------------------
# 0b) Restrict DV to partial advice use: 0 < s < 1
# ------------------------------------------------------------------------------
d_partial <- d %>%
  filter(s > 0, s <= 1)

cat("\n--- Partial-use sample size ---\n")
cat("n rows (trials) =", nrow(d_partial), "\n")
cat("n participants  =", n_distinct(d_partial$participant), "\n")

stopifnot(nrow(d_partial) > 0)

# Smithson–Verkuilen squeeze for beta regression (after filtering)
N <- nrow(d_partial)
d_partial <- d_partial %>%
  mutate(
    s_sv = (s * (N - 1) + 0.5) / N
  )

# ------------------------------------------------------------------------------
# Contrasts for Type III tests
# ------------------------------------------------------------------------------
contrasts(d_partial$Advice)          <- contr.sum(2)
contrasts(d_partial$Directed_Motion) <- contr.sum(2)
contrasts(d_partial$Synchrony)       <- contr.sum(3)

# ------------------------------------------------------------------------------
# 1) Baseline model (no within-person confidence moderation)
# ------------------------------------------------------------------------------
m_base <- glmmTMB(
  s_sv ~ Advice * Directed_Motion * Synchrony + absA_z + conf_BP_z + (1 | participant),
  family = beta_family(link = "logit"),
  data = d_partial
)

# ------------------------------------------------------------------------------
# 2) Moderation models (A, B, Full)
# ------------------------------------------------------------------------------
m_fullmod <- glmmTMB(
  s_sv ~ Advice * Directed_Motion * Synchrony +
    absA_z + conf_BP_z +
    conf_WP * Advice * Directed_Motion +
    conf_WP * Advice * Synchrony +
    (1 | participant),
  family = beta_family(link = "logit"),
  data = d_partial
)

m_Aonly <- glmmTMB(
  s_sv ~ Advice * Directed_Motion * Synchrony +
    absA_z + conf_BP_z +
    conf_WP * Advice * Directed_Motion +
    (1 | participant),
  family = beta_family(link = "logit"),
  data = d_partial
)

m_Bonly <- glmmTMB(
  s_sv ~ Advice * Directed_Motion * Synchrony +
    absA_z + conf_BP_z +
    conf_WP * Advice * Synchrony +
    (1 | participant),
  family = beta_family(link = "logit"),
  data = d_partial
)

# ------------------------------------------------------------------------------
# 3) Model comparisons
# ------------------------------------------------------------------------------
print_lrt(m_base,  m_fullmod, "LRT: baseline vs FULL moderation (A + B)")
print_lrt(m_Aonly, m_fullmod, "LRT: Is Branch B needed?  (A-only vs Full)")
print_lrt(m_Bonly, m_fullmod, "LRT: Is Branch A needed?  (B-only vs Full)")

p_overall <- anova(m_base,  m_fullmod)$`Pr(>Chisq)`[2]
p_needB   <- anova(m_Aonly, m_fullmod)$`Pr(>Chisq)`[2]  # adding B
p_needA   <- anova(m_Bonly, m_fullmod)$`Pr(>Chisq)`[2]  # adding A

cat("\n--- Key p-values ---\n")
cat("Overall moderation (Base -> Full): p =", signif(p_overall, 4), "\n")
cat("Need Branch B given A (A-only -> Full): p =", signif(p_needB, 4), "\n")
cat("Need Branch A given B (B-only -> Full): p =", signif(p_needA, 4), "\n")

# ------------------------------------------------------------------------------
# 4) Choose TARGET model (transparent rule)
# ------------------------------------------------------------------------------
alpha <- 0.05

if (!is.na(p_needA) && p_needA < alpha && !is.na(p_needB) && p_needB < alpha) {
  cat("\n>>> TARGET = FULL moderation (A + B)\n")
  m_target <- m_fullmod
} else if (!is.na(p_needA) && p_needA < alpha && (is.na(p_needB) || p_needB >= alpha)) {
  cat("\n>>> TARGET = A-only moderation (conf_WP × Advice × Directed Motion)\n")
  m_target <- m_Aonly
} else if (!is.na(p_needB) && p_needB < alpha && (is.na(p_needA) || p_needA >= alpha)) {
  cat("\n>>> TARGET = B-only moderation (conf_WP × Advice × Synchrony)\n")
  m_target <- m_Bonly
} else {
  cat("\n>>> TARGET = Baseline (no supported moderation branch)\n")
  m_target <- m_base
}

# ------------------------------------------------------------------------------
# 5) Inference on TARGET model
# ------------------------------------------------------------------------------
cat("\n--- Type III Wald tests (TARGET) ---\n")
print(car::Anova(m_target, type = "III"))

cat("\n--- Fixed effects (TARGET; logit scale) ---\n")
print(summary(m_target))

# ------------------------------------------------------------------------------
# 6) Probing simple effects for TARGET model (no confidence moderation retained)
# ------------------------------------------------------------------------------

at_cov <- list(absA_z = 0, conf_BP_z = 0)

# ------------------------------------------------------------------------------
# A) Advice × Directed Motion
# ------------------------------------------------------------------------------

# Advice within Directed Motion (logit scale)
em_adv_byDM_link <- emmeans(
  m_target,
  ~ Advice | Directed_Motion,
  at = at_cov,
  type = "link",
  weights = "equal"
)

cat("\n--- Advice within Directed Motion (logit scale) ---\n")
print(em_adv_byDM_link)

cat("\n--- Advice contrast (Under − Over) within Directed Motion ---\n")
adv_contr_byDM <- pairs(em_adv_byDM_link, adjust = "none")
print(adv_contr_byDM)

cat("\n--- Advice contrast with 95% CIs ---\n")
print(confint(adv_contr_byDM, level = 0.95))


# Directed Motion within Advice (logit scale)
em_DM_byAdv_link <- emmeans(
  m_target,
  ~ Directed_Motion | Advice,
  at = at_cov,
  type = "link",
  weights = "equal"
)

cat("\n--- Directed Motion within Advice (logit scale) ---\n")
print(em_DM_byAdv_link)

cat("\n--- Directed Motion contrast (Present − Absent) within Advice ---\n")
dm_contr_byAdv <- pairs(em_DM_byAdv_link, adjust = "none")
print(dm_contr_byAdv)

cat("\n--- Directed Motion contrast with 95% CIs ---\n")
print(confint(dm_contr_byAdv, level = 0.95))


# ------------------------------------------------------------------------------
# B) Advice × Synchrony
# ------------------------------------------------------------------------------

em_adv_bySyn_link <- emmeans(
  m_target,
  ~ Advice | Synchrony,
  at = at_cov,
  type = "link",
  weights = "equal"
)

cat("\n--- Advice within Synchrony (logit scale) ---\n")
print(em_adv_bySyn_link)

cat("\n--- Advice contrast (Under − Over) within Synchrony ---\n")
adv_contr_bySyn <- pairs(em_adv_bySyn_link, adjust = "none")
print(adv_contr_bySyn)

cat("\n--- Advice contrast with 95% CIs ---\n")
print(confint(adv_contr_bySyn, level = 0.95))

# ------------------------------------------------------------------------------
# Exploratory: Categorical Switch (Descriptive, no models)
# ------------------------------------------------------------------------------

d_switch <- read_csv(file.path(output_dir, "siu_trials_clean.csv"), show_col_types = FALSE) %>%
  transmute(
    participant = factor(participant),
    R1 = suppressWarnings(as.numeric(slider_response1_2.response)),
    R2 = suppressWarnings(as.numeric(slider_response2_2.response)),
    X  = suppressWarnings(as.numeric(agent_feedback)),
    feedback_type = str_to_lower(feedback_type)
  ) %>%
  # keep only real advice (drop random)
  filter(feedback_type %in% c("under", "over")) %>%
  mutate(
    # categorical coding around 0
    cat_R1 = case_when(R1 > 0 ~ "Yes", R1 < 0 ~ "No", TRUE ~ NA_character_),
    cat_R2 = case_when(R2 > 0 ~ "Yes", R2 < 0 ~ "No", TRUE ~ NA_character_),
    cat_X  = case_when(X  > 0 ~ "Yes", X  < 0 ~ "No", TRUE ~ NA_character_),
    
    # any categorical switch?
    switch_any = as.integer(!is.na(cat_R1) & !is.na(cat_R2) & cat_R1 != cat_R2),
    
    # is advice categorically opposite to initial judgment?
    advice_opposite = as.integer(!is.na(cat_R1) & !is.na(cat_X) & cat_R1 != cat_X),
    
    # distance measures you wanted
    absR1 = abs(R1),         # distance of initial response from midpoint
    absX  = abs(X)           # distance of advice from midpoint
  ) %>%
  # keep trials where both R1 and R2 have a category
  filter(!is.na(cat_R1), !is.na(cat_R2)) %>%
  droplevels()


# -----------------------------
# 1) Overall flip rate
# -----------------------------
overall_flip_rate <- mean(d_switch$switch_any)
n_flips  <- sum(d_switch$switch_any)
n_trials <- nrow(d_switch)

cat("\nOverall flip rate:", round(overall_flip_rate, 3),
    "\nFlips:", n_flips,
    "\nTotal trials:", n_trials, "\n")


# -----------------------------
# 2) Directional switches (conflict trials only)
# -----------------------------
d_conflict_dir <- d_switch %>%
  filter(advice_opposite == 1) %>%
  mutate(
    switch_direction = case_when(
      cat_R1 == "No"  & cat_R2 == "Yes" ~ "No_to_Yes",
      cat_R1 == "Yes" & cat_R2 == "No"  ~ "Yes_to_No",
      TRUE ~ "No_Switch"
    )
  )

direction_counts <- d_conflict_dir %>% count(switch_direction)
print(direction_counts)

n_no_to_yes <- sum(d_conflict_dir$switch_direction == "No_to_Yes")
n_yes_to_no <- sum(d_conflict_dir$switch_direction == "Yes_to_No")
n_total_switches <- n_no_to_yes + n_yes_to_no

cat("\nNo→Yes:", n_no_to_yes,
    "\nYes→No:", n_yes_to_no,
    "\nTotal directional switches:", n_total_switches, "\n")

if (n_total_switches > 0) {
  cat("\nBinomial test (50/50 split among switchers):\n")
  print(binom.test(n_no_to_yes, n_total_switches, p = 0.5))
}


# -----------------------------
# 3) Conditional switch rates (given conflict)
# -----------------------------
conditional_rates <- d_conflict_dir %>%
  group_by(cat_R1) %>%
  summarise(
    n_trials = n(),
    n_switch = sum(switch_any),
    switch_rate = mean(switch_any),
    .groups = "drop"
  )

print(conditional_rates)

n_no_trials  <- conditional_rates$n_trials[conditional_rates$cat_R1 == "No"]
n_yes_trials <- conditional_rates$n_trials[conditional_rates$cat_R1 == "Yes"]
n_no_switch  <- conditional_rates$n_switch[conditional_rates$cat_R1 == "No"]
n_yes_switch <- conditional_rates$n_switch[conditional_rates$cat_R1 == "Yes"]

cat("\nTwo-proportion test (conditional switch rates):\n")
print(prop.test(
  x = c(n_no_switch, n_yes_switch),
  n = c(n_no_trials, n_yes_trials)
))


# -----------------------------
# 4) Distance descriptives (conflict trials)
# -----------------------------
dist_summary <- d_conflict_dir %>%
  mutate(switched = if_else(switch_any == 1, "Switch", "No_Switch")) %>%
  group_by(cat_R1, switched) %>%
  summarise(
    n = n(),
    mean_absX = mean(absX, na.rm = TRUE),
    sd_absX   = sd(absX, na.rm = TRUE),
    mean_absR1 = mean(absR1, na.rm = TRUE),
    sd_absR1   = sd(absR1, na.rm = TRUE),
    .groups = "drop"
  )

cat("\nDistance summary (conflict trials):\n")
print(dist_summary)
