# Assign stimulus_id to condition
df <- df %>%
  mutate(condition = case_when(
    stimulus_id >= 1  & stimulus_id <= 10  ~ "HSDA",
    stimulus_id >= 11 & stimulus_id <= 20  ~ "HSDP",
    stimulus_id >= 21 & stimulus_id <= 30  ~ "LSDA",
    stimulus_id >= 31 & stimulus_id <= 40  ~ "LSDP",
    TRUE ~ NA_character_
  ))

stopifnot(!any(is.na(df$condition)))

simulate_feedback_proportions <- function(data, condition_name, n_sim = 100) {
  data_cond <- data %>% filter(condition == condition_name)
  
  trials <- list()
  feedback_counts <- rep(0, 6)  # indices 1 to 6 for 0/5 to 5/5
  i <- 0
  
  while (length(trials) < n_sim && i < 10000) {
    i <- i + 1
    
    # Sample 5 responses from different participants
    sample_group <- data_cond %>%
      group_by(participant) %>%
      slice_sample(n = 1) %>%
      ungroup() %>%
      slice_sample(n = 5)
    
    if (nrow(sample_group) < 5) next
    
    n_yes <- sum(sample_group$response, na.rm = TRUE)
    
    # Safeguard: skip if n_yes is invalid
    if (is.na(n_yes) || n_yes < 0 || n_yes > 5) next
    
    feedback_level <- paste0(n_yes, "/5")
    
    # Index for counts is (n_yes + 1) because R uses 1-based indexing
    index <- n_yes + 1
    
    # Ensure all feedback levels (0 to 5) appear at least once
    if (feedback_counts[index] == 0 || sum(feedback_counts) >= 5) {
      trials[[length(trials) + 1]] <- tibble(
        condition = condition_name,
        feedback_level = feedback_level
      )
      feedback_counts[index] <- feedback_counts[index] + 1
    }
  }
  
  if (length(trials) < n_sim) {
    warning(paste("Only", length(trials), "samples generated for", condition_name))
  }
  
  bind_rows(trials)
}


# Run simulation
set.seed(123)
conditions <- c("HSDA", "HSDP", "LSDA", "LSDP")

simulated_feedback <- map_dfr(conditions, ~simulate_feedback_proportions(df, .x, n_sim = 100))

# ----------------------------
# ANALYSIS & VISUALIZATION
# ----------------------------

# Table of feedback levels per condition
feedback_counts <- simulated_feedback %>%
  count(condition, feedback_level)

print(feedback_counts)

# Plot feedback level distribution by condition
ggplot(feedback_counts, aes(x = feedback_level, y = n, fill = feedback_level)) +
  geom_col() +
  facet_wrap(~condition) +
  labs(
    title = "Simulated Social Feedback (100 Trials per Condition)",
    x = "Number of Participants Saying YES",
    y = "Trial Count"
  ) +
  theme_minimal()

# Wide format summary
feedback_counts %>%
  pivot_wider(names_from = feedback_level, values_from = n, values_fill = 0)
